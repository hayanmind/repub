{
  "name": "@gov-epub/core",
  "version": "1.0.0",
  "description": "ePub 2.0 → 3.0 변환 핵심 엔진",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./parser": "./dist/parser/index.js",
    "./converter": "./dist/converter/index.js",
    "./accessibility": "./dist/accessibility/index.js",
    "./interaction": "./dist/interaction/index.js",
    "./validator": "./dist/validator/index.js"
  },
  "bin": {
    "epub-remaster": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "htmlparser2": "^9.1.0",
    "dom-serializer": "^2.0.0",
    "domhandler": "^5.0.3",
    "domutils": "^3.1.0",
    "css-tree": "^3.0.0",
    "openai": "^4.60.0",
    "uuid": "^10.0.0",
    "chardet": "^2.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0"
  }
}
